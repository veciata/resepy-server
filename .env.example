PORT=3001
HOST=0.0.0.0
NODE_ENV=development

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=tsresepy_user
DB_PASSWORD=your_password_here
DB_NAME=tsresepy_db

# Optional: use root only for `npm run db:init`, then remove these lines
# DB_ADMIN_USER=root
# DB_ADMIN_PASSWORD=your_root_password

JWT_ACCESS_SECRET=generate_a_long_random_access_secret
JWT_REFRESH_SECRET=generate_a_long_random_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Social login (server verifies tokens from the mobile app)
GOOGLE_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

ADMIN_EMAIL=admin@tsresepy.local
ADMIN_PASSWORD=admin12345
ADMIN_USERNAME=admin
